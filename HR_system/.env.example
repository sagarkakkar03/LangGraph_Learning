# OpenAI
OPENAI_API_KEY=sk-...

# SMTP (Gmail example — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Department emails (override defaults)
EMAIL_MAIN=hr@company.com
EMAIL_PEOPLE_TEAM=peopleteam@company.com
EMAIL_PAYROLL=payroll@company.com
EMAIL_BENEFITS=benefits@company.com
EMAIL_TALENT_DEV=talentdevelopment@company.com
EMAIL_ONBOARDING=onboarding@company.com
EMAIL_COMPLIANCE=compliance@company.com
EMAIL_RECRUITMENT=recruitment@company.com
EMAIL_IT_SUPPORT=itsupport@company.com
